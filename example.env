# ============================================
# Gallery-360: Multimedia Memorial Module
# Environment Variables Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_NAME="Gallery-360"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="development"

# ============================================
# LOCAL DEVELOPMENT
# ============================================
# Path to local media directory for testing
# Default: ~/temp/media (resolved at runtime)
LOCAL_MEDIA_PATH="~/temp/media"

# Enable local media bridge (set to false in production)
NEXT_PUBLIC_USE_LOCAL_MEDIA="true"

# ============================================
# SUPABASE (Database & Auth)
# ============================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================
# AI SERVICES
# ============================================
# Vercel AI Gateway (default, zero config for supported providers)
# Supported: openai, anthropic, google, aws-bedrock, fireworks
AI_GATEWAY_MODEL="openai/gpt-4o-mini"

# For image analysis and face detection
AI_VISION_MODEL="openai/gpt-4o"

# ============================================
# IMMICH API (Self-hosted Face Recognition)
# ============================================
IMMICH_API_URL="http://localhost:2283/api"
IMMICH_API_KEY="your-immich-api-key"

# ============================================
# AWS REKOGNITION (Content Moderation)
# ============================================
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"

# ============================================
# STORAGE
# ============================================
# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="your-blob-token"

# ============================================
# FEATURE FLAGS
# ============================================
# Enable AI face detection (requires AI_GATEWAY_API_KEY or Immich)
NEXT_PUBLIC_ENABLE_FACE_DETECTION="true"

# Enable AI content moderation (requires AWS credentials)
NEXT_PUBLIC_ENABLE_CONTENT_MODERATION="false"

# Enable voice note recording for story tagging
NEXT_PUBLIC_ENABLE_VOICE_NOTES="true"

# Enable social sharing features
NEXT_PUBLIC_ENABLE_SHARING="true"

# ============================================
# RATE LIMITING
# ============================================
# Maximum uploads per hour per user
UPLOAD_RATE_LIMIT="50"

# Maximum AI processing requests per hour
AI_RATE_LIMIT="100"

# ============================================
# ANALYTICS (Optional)
# ============================================
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

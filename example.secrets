# ============================================
# Gallery-360: Sensitive Credentials
# ============================================
# SECURITY WARNING: Never commit this file to version control!
# Copy to .secrets.local and add to .gitignore

# ============================================
# DATABASE CREDENTIALS
# ============================================
# Supabase Service Role Key (full database access)
# Used for server-side operations and admin tasks
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Database connection string (for direct PostgreSQL access)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ============================================
# AI SERVICE KEYS
# ============================================
# Vercel AI Gateway API Key (for non-default providers)
AI_GATEWAY_API_KEY="vgw_..."

# OpenAI API Key (if using directly)
OPENAI_API_KEY="sk-..."

# Anthropic API Key (if using directly)
ANTHROPIC_API_KEY="sk-ant-..."

# ============================================
# AWS CREDENTIALS
# ============================================
# AWS IAM credentials for Rekognition
# Requires: rekognition:DetectFaces, rekognition:DetectModerationLabels
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."

# ============================================
# IMMICH CREDENTIALS
# ============================================
# API key for self-hosted Immich instance
IMMICH_API_KEY="..."

# ============================================
# STORAGE CREDENTIALS
# ============================================
# Vercel Blob read/write token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ============================================
# ENCRYPTION
# ============================================
# Used for encrypting sensitive user data at rest
ENCRYPTION_KEY="32-character-encryption-key-here"

# JWT secret for custom auth tokens
JWT_SECRET="your-jwt-secret-min-32-chars"

# ============================================
# WEBHOOK SECRETS
# ============================================
# For verifying incoming webhooks
WEBHOOK_SECRET_SUPABASE="whsec_..."

# ============================================
# ADMIN CREDENTIALS
# ============================================
# Initial admin account (for seeding)
ADMIN_EMAIL="admin@funeralhome.com"
ADMIN_PASSWORD="change-this-password"

# ============================================
# RATE LIMITING KEYS
# ============================================
# Upstash Redis (for production rate limiting)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."
